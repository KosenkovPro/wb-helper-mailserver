# ============================================================================
# docker-mailserver — невекретные настройки (версионируются в git)
# ----------------------------------------------------------------------------
# Полный референс: https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/
#
# Секреты (домен, postmaster, SSL_TYPE) приходят через docker-compose.yml из .env.
# Меняешь что-то здесь — push в main, деплой прогонит `docker compose up -d`.
# ============================================================================

# ----- Общие -----
OVERRIDE_HOSTNAME=
DMS_DEBUG=0
SUPERVISOR_LOGLEVEL=info
# UTF-8 имена ящиков (utf8mb4-safe).
ENABLE_POSTFIX_VIRTUAL_TRANSPORT=0

# ----- Включение/отключение сервисов -----
ENABLE_SPAMASSASSIN=1
ENABLE_CLAMAV=0           # тяжёлый, жрёт RAM — выключен; включи если нужен антивирус
ENABLE_AMAVIS=1
ENABLE_FAIL2BAN=1
ENABLE_POSTGREY=0         # серый список — повышает задержку первого письма; по умолчанию off
ENABLE_SASLAUTHD=0
ENABLE_MANAGESIEVE=1
ENABLE_OPENDKIM=1
ENABLE_OPENDMARC=1
ENABLE_POLICYD_SPF=1
ENABLE_SRS=0

# ----- Пороги спама -----
SPAMASSASSIN_SPAM_TO_INBOX=1
SA_TAG=2.0
SA_TAG2=6.31
SA_KILL=10.0
MOVE_SPAM_TO_JUNK=1

# ----- Почтовые протоколы -----
# 0 — IMAP(S)/POP3(S) выключен, 1 — включен.
# Оставляем только IMAPS (993) + SUBMISSIONS (465) + SUBMISSION (587).
# POP3 и незащищённый IMAP (143) — выключены.
SMTP_ONLY=0
SSL_TYPE=letsencrypt
TLS_LEVEL=modern

ENABLE_POP3=0
POP3_PORT=110
POP3_SSL_PORT=995

# ----- Ретеншн / квоты -----
ENABLE_QUOTAS=1
POSTFIX_MESSAGE_SIZE_LIMIT=25000000   # 25 MB — лимит одного письма
POSTFIX_MAILBOX_SIZE_LIMIT=0          # 0 — без общего лимита (квоты через dovecot)

# ----- Логи -----
LOG_LEVEL=info
LOGROTATE_INTERVAL=weekly
UPDATE_CHECK_INTERVAL=1d

# ----- Fail2Ban -----
# Стандартная тюрьма + jail на postfix/dovecot/sasl.
FAIL2BAN_BLOCKTYPE=drop

# ----- Network / relay -----
# Никаких open relay — MTA принимает письма только для своих доменов
# и от аутентифицированных клиентов.
PERMIT_DOCKER=none

# ----- DNSBL / проверки входящих -----
ENABLE_DNSBL=0             # по желанию; 1 включит zen.spamhaus.org и т.п.

# ----- Прочее -----
ONE_DIR=1
ACCOUNT_PROVISIONER=FILE   # файловый провиженинг (postfix-accounts.cf в ./config)
