# ============================================================================
# wb-helper-mailserver — локальные значения для docker-compose
# ----------------------------------------------------------------------------
# На проде эти переменные приходят из GitHub Secrets через .github/workflows/
# deploy.yml: они пишутся в .env на сервере БД bison перед
# `docker compose up -d`.
# Сюда коммитим только шаблон — реальный .env в .gitignore.
# ============================================================================

# FQDN почтового сервера — совпадает с A/AAAA-записью и CN на TLS-сертификате.
# Именно этот хост анонсирует MX-запись домена wb-helper.tech.
MAIL_HOSTNAME=mail.wb-helper.tech

# Адрес постмастера — автоматически создаётся как алиас на первый аккаунт,
# на него шлются жалобы/DMARC-отчёты, и он обязан существовать (RFC 5321).
POSTMASTER_ADDRESS=postmaster@wb-helper.tech

# IP, на который биндить публичные порты.
# Если у lion единственный публичный интерфейс — оставь 0.0.0.0.
# Если мэйл идёт на отдельный публичный IP — укажи его тут.
MAIL_BIND_IP=0.0.0.0

# Тип TLS:
#   letsencrypt — монтируем /etc/letsencrypt/live/${MAIL_HOSTNAME}/ (certbot на хосте)
#   manual      — кладём сертификаты в ./config/ssl/ и указываем SSL_CERT_PATH/SSL_KEY_PATH
#   self-signed — только для dev
SSL_TYPE=letsencrypt
